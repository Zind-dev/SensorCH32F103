{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD)",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.buildDirectory}/firmware.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "showDevDebugOutput": "raw",
            "gdbPath": "${config:cortex-debug.gdbPath.windows}",
            "objdumpPath": "${config:cortex-debug.objdumpPath.windows}",
            "svdFile": "${workspaceFolder}/wch/CH32V003xx.svd",
            "configFiles": [
                "${workspaceFolder}/wch/wch-riscv.cfg"
            ],
            "postLaunchCommands": [
                "set mem inaccessible-by-default off",
                "set architecture riscv:rv32",
                "set remotetimeout unlimited"
            ],
            "preLaunchTask": "🚀⚙️ OpenOCD flash"
        }
    ]
}